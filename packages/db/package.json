{
  "name": "@sigef/db",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma && npx tsc",
    "dev": "tsc --watch",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts",
    "db:reset": "prisma migrate reset --force --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "devDependencies": {
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}